<IfModule mod_rewrite.c>
  RewriteEngine On
  RewriteBase /
  
  # Handle SPA Routing: If the requested file or directory doesn't exist, route to index.html
  RewriteRule ^index\.html$ - [L]
  RewriteCond %{REQUEST_FILENAME} !-f
  RewriteCond %{REQUEST_FILENAME} !-d
  RewriteRule . /index.html [L]
</IfModule>

<IfModule mod_headers.c>
  # 1. Disable caching for HTML and Service Worker files (Forces browsers to always get the latest version)
  <FilesMatch "\.(html|htm|json)$|sw\.js$">
    Header set Cache-Control "no-cache, no-store, must-revalidate"
    Header set Pragma "no-cache"
    Header set Expires "0"
  </FilesMatch>

  # 2. Aggressively cache static assets (Vite hashes JS and CSS, so they can be cached forever)
  <FilesMatch "\.(js|css|png|jpg|jpeg|gif|webp|svg|ico|woff|woff2|ttf|eot)$">
    # Skip sw.js as it must not be cached
    <If "%{REQUEST_URI} !~ m#/sw\.js$#">
      Header set Cache-Control "public, max-age=31536000, immutable"
    </If>
  </FilesMatch>
</IfModule>

<IfModule mod_expires.c>
  ExpiresActive On
  
  # Default to NO caching to prevent old files from lingering
  ExpiresDefault "access plus 0 seconds"
  
  ExpiresByType text/html "access plus 0 seconds"
  ExpiresByType application/json "access plus 0 seconds"
  
  # Cache assets for 1 year
  ExpiresByType image/jpg "access plus 1 year"
  ExpiresByType image/jpeg "access plus 1 year"
  ExpiresByType image/png "access plus 1 year"
  ExpiresByType image/gif "access plus 1 year"
  ExpiresByType image/webp "access plus 1 year"
  ExpiresByType image/svg+xml "access plus 1 year"
  ExpiresByType image/x-icon "access plus 1 year"
  
  ExpiresByType application/javascript "access plus 1 year"
  ExpiresByType text/javascript "access plus 1 year"
  ExpiresByType text/css "access plus 1 year"
  
  ExpiresByType font/woff2 "access plus 1 year"
</IfModule>

<IfModule mod_deflate.c>
  # Enable gzip compression for faster loads
  AddOutputFilterByType DEFLATE text/html text/plain text/css application/json application/javascript text/xml application/xml application/xml+rss text/javascript image/svg+xml
</IfModule>
